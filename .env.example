# JWT Secret Key
# Change this to a secure random string in production
JWT_SECRET=your-secret-key-change-in-production

# Super Admin Key for Emergency Admin Promotion
# This key allows emergency promotion of users to admin status
# Keep this key secure and only share with trusted system administrators
# Generate a strong random key: openssl rand -base64 32
SUPER_ADMIN_KEY=your-super-admin-key-change-in-production

# Server Port
PORT=3001

# Node Environment
NODE_ENV=production